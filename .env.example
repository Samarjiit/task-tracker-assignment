# ---- Database ----
POSTGRES_USER=tasktracker
POSTGRES_PASSWORD=tasktracker
POSTGRES_DB=tasktracker
# Used by the backend (host "postgres" is the compose service name)
DATABASE_URL=postgresql://tasktracker:tasktracker@postgres:5432/tasktracker?schema=public

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=604800        # 7 days (seconds)

# ---- App ----
PORT=3000
NODE_ENV=development
TASK_CACHE_TTL=60             # seconds
